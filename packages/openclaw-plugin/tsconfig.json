{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": false,
    "ignoreDeprecations": "6.0",
    "declaration": false,
    "declarationMap": false
  },
  "include": ["index.ts", "setup-entry.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
