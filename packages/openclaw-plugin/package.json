{
  "name": "@w3osc/openclaw-conduit",
  "version": "1.0.10",
  "description": "OpenClaw channel plugin that connects Conduit as a native messaging channel",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./setup": "./dist/setup-entry.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "conduit",
      "label": "Conduit",
      "blurb": "Connect OpenClaw to Conduit — a self-hosted personal communications hub.",
      "exposure": {
        "configured": true,
        "setup": true
      }
    },
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  },
  "keywords": [
    "openclaw",
    "conduit",
    "channel",
    "plugin"
  ],
  "license": "MIT",
  "devDependencies": {
    "openclaw": "latest",
    "typescript": "^6.0.2",
    "@types/node": "^22.10.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  }
}
